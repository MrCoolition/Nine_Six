VITE_PARTY_MODE_ENABLED=true
VITE_PARTY_DEMO_ENABLED=true

# Server-only runtime configuration. Vercel Functions expose only safe SPA values.
DB_CONNECT=
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-spa-client-id
AUTH0_AUDIENCE=https://api.nine-six.example
AUTH0_SCOPE=openid profile email offline_access
AUTH0_SECRET=
AUTH0_CLIENT_SECRET=

# Optional compile-time/local fallback values.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# Legacy Supabase Party-action backend. Neon shared standings do not require these.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Legacy server-only Supabase moderation values.
AUTH0_ISSUER_BASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CHAT_BLOCKLIST=
PARTY_MODE_ENABLED=true
PARTY_PUBLIC_ROOMS_ENABLED=true
PARTY_CHAT_ENABLED=true
PARTY_WALLET_SETTLEMENT_ENABLED=true
